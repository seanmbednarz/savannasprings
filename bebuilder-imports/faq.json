post", "query_post_orderby": "date", "query_post_order": "DESC", "query_terms_taxonomy": "category", "query_terms_orderby": "ID", "query_terms_order": "ASC", "query_slider_columns": {"desktop": "1"}, "background_switcher_ql": "default", "query_display_slider_arrow_prev": "icon-left-open-big", "query_display_slider_arrow_next": "icon-right-open-big", "background_switcher": "default", "background_switcher_hover": "default", "background_overlay_switcher": "default", "custom-responsive": "hide", "vb_postid": "0", "vb": 1, "rwd": "desktop"}, "title": "Wrap", "laptop_size": "1/1", "tablet_resized": "0", "items": [{"type": "faq", "jsclass": "faq", "title": "FAQ", "icon": "faq", "attr": {"style": "accordion", "tabs": [{"title": "What causes hard water, and why should I treat it?", "content": "<p>Hard water is high in dissolved calcium and magnesium. It leaves scale in your pipes and water heater, spots your dishes, stiffens laundry, and makes you use more soap. A softener removes those minerals at the source.</p><p><a href=\"/water-problems/hard-water/\">Hard water &amp; scale &rarr;</a></p>"}, {"title": "Why does my water smell like rotten eggs?", "content": "<p>That smell is hydrogen sulfide gas, usually produced by iron and sulfur bacteria. Our self-sanitizing Sanitizer Plus with Crystal-Right&reg; kills the odor-causing bacteria and rinses clean.</p><p><a href=\"/water-problems/rotten-egg-smell/\">Rotten-egg smell &rarr;</a></p>"}, {"title": "What kind of salt should I use in my softener?", "content": "<p>We recommend Pro&rsquo;s Pick Dura-Cube&reg; &mdash; up to 99.8% pure and virtually 100% soluble. Even better: let us deliver it and load it for you.</p><p><a href=\"/products/salt-delivery/\">Salt delivery &rarr;</a></p>"}, {"title": "Will a water softener work with my septic system?", "content": "<p>Yes. Modern demand-based softeners regenerate only when needed and use up to 75% less water and 60% less salt than old time-clock units.</p><p><a href=\"/products/water-softeners/\">Water softeners &rarr;</a></p>"}, {"title": "Do you service systems you didn&rsquo;t install?", "content": "<p>Yes &mdash; we service all makes and models, whoever installed them, plus salt and water delivery.</p><p><a href=\"/products/\">Browse products &rarr;</a></p>"}, {"title": "Is the in-home water test really free?", "content": "<p>Completely free, with no obligation and no pressure. A licensed operator tests your water on-site, and we&rsquo;ll call within 24 business hours to schedule.</p><p><a href=\"/free-water-test/\">Book a free test &rarr;</a></p>"}], "classes": "ss-faqnative", "vb_postid": "0", "vb": 1, "rwd": "desktop"}, "uid": "qcz0lq4j", "size": "1/1", "tablet_size": "1/1", "laptop_size": "1/1", "mobile_size": "1/1", "tablet_resized": "0"}]}]}, {"icon": "section", "uid": "y3tdu47x", "jsclass": "section", "title": "Section", "attr": {"scroll-visibility": "show", "closeable-x": "left", "tabber_nav_position": {"desktop": "left"}, "query_post_orderby": "date", "query_post_order": "DESC", "query_terms_taxonomy": "category", "query_terms_orderby": "ID", "query_terms_order": "ASC", "css_tabber_gap": {"desktop": "30"}, "tabber_icon_position": {"desktop": "left"}, "query_slider_columns": {"desktop": "1"}, "background_switcher_ql": "default", "query_display_slider_arrow_prev": "icon-left-open-big", "query_display_slider_arrow_next": "icon-right-open-big", "background_switcher": "default", "background_switcher_hover": "default", "background_switcher_scroll": "default", "background_overlay_switcher": "default", "vb_postid": "0", "vb": 1, "rwd": "desktop", "css_advanced_padding": {"val": {"desktop": {"top": "0px", "bottom": "64px"}}, "selector": ".mcb-section-mfnuidelement", "style": "padding"}}, "ver": "default", "wraps": [{"icon": "wrap", "uid": "kj87in3m", "size": "1/1", "tablet_size": "1/1", "mobile_size": "1/1", "jsclass": "wrap", "attr": {"css_grid_columns": {"val": {"desktop": "repeat(3, 1fr)"}, "selector": ".mcb-section .mcb-wrap-grid.mcb-wrap